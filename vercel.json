{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/Register", "dest": "/public/register.html" },
    { "src": "/homepage", "dest": "/public/homepage.html" },
    { "src": "/privacy_policy", "dest": "/public/privacy_policy.html" },
    { "src": "/terms_of_service", "dest": "/public/terms_of_service.html" },
    { "src": "/(.*\\..*)", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
